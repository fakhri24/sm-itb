# Contoh konfigurasi Supabase (SALIN ke .env dan isi nilai asli — .env TIDAK di-commit).
# Catatan: publishable key memang aman dipublik (privilege rendah), tapi tetap
# kita pisahkan agar rapi & mudah diganti. JANGAN taruh secret key (sb_secret_...) di sini.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
